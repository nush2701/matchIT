// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "sqlite"
  // Placeholder only — the real connection to Turso is handled by the
  // libSQL driver adapter (see lib/prisma.ts and prisma.config.ts).
  url      = "file:./dev.db"
}

model User {
  id              String           @id @default(cuid())
  name            String?
  email           String           @unique
  emailVerified   DateTime?        // <-- ADD THIS
  image           String?
  password        String?          // for credentials auth (optional)
  createdAt       DateTime         @default(now())

  accounts        Account[]        // <-- for OAuth (required by NextAuth)
  sessions        Session[]        // <-- for session handling
  wardrobe        WardrobeItem[]   // your custom model
  profile         UserProfile?     // 1:1 style/personalization profile
}

// Per-user style profile, captured by the onboarding quiz.
// NOTE: SQLite (via Prisma) has no enums or scalar lists, so single choices
// are validated Strings and multi-selects are stored as JSON-encoded strings.
model UserProfile {
  id        String  @id @default(cuid())
  userId    String  @unique
  user      User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  onboarded Boolean @default(false)

  // single choice
  gender        String? // "woman" | "man" | "nonbinary" | "na"
  shopFor       String? // "womenswear" | "menswear" | "unisex"
  fitPreference String? // "fitted" | "regular" | "relaxed"
  budget        String? // "budget" | "mid" | "premium"
  vibe          String? // "timeless" | "trendy"
  statement     String? // "minimal" | "bold"

  // multi choice (JSON arrays as strings)
  styles         String? // ["minimalist","streetwear"]
  occasions      String? // ["work","night out"]
  colorPalette   String? // ["neutrals","earth tones"]
  avoidColors    String? // ["neon"]
  favoriteBrands String? // free text or ["uniqlo"]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}


model WardrobeItem {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id])

  name     String
  type     String // e.g. top, bottom, shoes
  color    String?
  imageUrl String? // for future image uploads

  createdAt DateTime @default(now())
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}
